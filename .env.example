# ── Django core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=prokar.uz,www.prokar.uz,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://prokar.uz,https://www.prokar.uz

# ── Database ──────────────────────────────────────────────────────────────────
# Set USE_SQLITE=False to use PostgreSQL (required for production)
USE_SQLITE=False
DB_NAME=prokar_db
DB_USER=prokar_user
DB_PASSWORD=your-strong-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Telegram notifications (optional) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
