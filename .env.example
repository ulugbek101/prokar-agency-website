SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Set to True for SQLite (development), False for PostgreSQL (production)
USE_SQLITE=True

# PostgreSQL (used when USE_SQLITE=False)
DB_NAME=prokar_db
DB_USER=prokar_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
