SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Set to True for SQLite (development), False for PostgreSQL (production)
USE_SQLITE=True

# PostgreSQL (used when USE_SQLITE=False)
DB_NAME=prokar_db
DB_USER=prokar_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# Telegram bot notifications (feedback form)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Comma-separated admin Telegram chat IDs
TELEGRAM_ADMIN_IDS=123456789,987654321
